# Copy to .env for LOCAL use only (never commit .env — it's gitignored).

# From your browser after logging into the throwaway X account:
# DevTools (F12) -> Application -> Cookies -> https://x.com -> copy each Value.
X_AUTH_TOKEN=
X_CT0=

# Bluesky account the bot posts to.
# Use an App Password (Settings -> Privacy and security -> App Passwords),
# NOT your main Bluesky password.
BSKY_HANDLE=nufcjournalistbot.bsky.social
BSKY_PASSWORD=xxxx-xxxx-xxxx-xxxx
